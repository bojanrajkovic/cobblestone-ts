{
  "name": "cobblestone-ts",
  "version": "0.0.0",
  "description": "Placeholder — TypeScript implementation of the C2SP chunked-encryption scheme (Cobblestone-128/256). Real releases start at 0.1.0.",
  "keywords": [
    "aes-gcm",
    "c2sp",
    "chunked-encryption",
    "cobblestone",
    "streaming-encryption",
    "webcrypto"
  ],
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bojanrajkovic/cobblestone-ts.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js",
    "./cobblestone-128": "./dist/cobblestone-128.js",
    "./cobblestone-256": "./dist/cobblestone-256.js",
    "./hazmat": "./dist/hazmat.js",
    "./errors": "./dist/errors.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "lint": "oxlint .",
    "fmt": "oxfmt --check .",
    "fmt:write": "oxfmt .",
    "test": "vitest run",
    "test:related": "vitest related --run"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=24"
  }
}
