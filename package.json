{
  "name": "cobblestone-ts",
  "version": "0.0.0",
  "description": "Placeholder — TypeScript implementation of the C2SP chunked-encryption scheme (Cobblestone-128/256). Real releases start at 0.1.0.",
  "license": "BSD-3-Clause",
  "type": "module",
  "sideEffects": false,
  "engines": { "node": ">=22.12" },
  "repository": { "type": "git", "url": "git+https://github.com/bojanrajkovic/cobblestone-ts.git" },
  "keywords": ["c2sp", "chunked-encryption", "cobblestone", "aes-gcm", "streaming-encryption", "webcrypto"],
  "files": ["dist"],
  "exports": {
    ".": "./dist/index.js",
    "./cobblestone-128": "./dist/cobblestone-128.js",
    "./cobblestone-256": "./dist/cobblestone-256.js",
    "./hazmat": "./dist/hazmat.js",
    "./errors": "./dist/errors.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "devDependencies": {
    "typescript": "7.0.2"
  }
}
